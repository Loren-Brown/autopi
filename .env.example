PI_HOSTNAME=autopi
PI_HOST=autopi.local
PI_USER=pi

# Guest WiFi access point SSID (QR code / phone join name)
AP_SSID=AUTOPI
# DNS name on the guest AP → http://autopi.lan:8080/ (dotted name; phones struggle with single-label hosts)
AP_HOSTNAME=autopi.lan

# CAN interface mode:
#   native     - use local can0 via SocketCAN (set this on the Pi)
#   socketcand - connect to can0 on the Pi over TCP (set this for local dev on your laptop)
CAN_MODE=socketcand
# When connecting via SSH tunnel, set SOCKETCAND_HOST=localhost and forward the port:
#   ssh -L 29536:localhost:29536 PI_USER@PI_HOST -N
SOCKETCAND_HOST=localhost
SOCKETCAND_PORT=29536

# SSM ECU ID — selects per-ECU extended addresses in the RomRaider map
# 5C42504007 = 2011 USDM Subaru STI (EJ257), stock ROM 22611AP850
# Override this with the ID read from your ECU's SSM init response if different
SSM_ECU_ID=5C42504007

# RomRaider logger definition XML (repo-relative or absolute).
# Dev: SSM reads this path directly (keep under docs/romraider/ — gitignored).
# Pi:  ./deploy.sh copies it to src/ssm-collector/configs/<same-filename>.xml
#      on the Pi only (not on your laptop). At runtime the Pi finds that *.xml
#      in configs/ by extension — no ROMRAIDER_XML needed on the Pi.
ROMRAIDER_XML=docs/romraider/logger_v370/logger_STD_EN_v370.xml

# SSM collector (./run_remote.sh --collector) — CAN polling + WebSocket feed
COLLECTOR_HOST=0.0.0.0
COLLECTOR_PORT=8090

# Dashboard UI (./run_remote.sh --web) — no CAN; connects to collector
WEB_HOST=0.0.0.0
WEB_PORT=8080
COLLECTOR_WS_URL=ws://localhost:8090/ws
